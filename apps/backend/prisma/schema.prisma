generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @db.Uuid
  email             String   @unique
  preferredLanguage String   @default("en")
  createdAt         DateTime @default(now())
  // One-time welcome-email guard (PR4b). null = not yet sent. Set atomically
  // (claim-then-send) the first time a brand-new user is provisioned. Existing
  // users created before this column stay null and are NEVER retroactively
  // emailed: the send path is reached only on genuine first-time provisioning
  // (the zero-memberships branch in authMiddleware), which pre-existing users
  // never enter. No backfill — safe additive nullable column.
  welcomeEmailSentAt DateTime?

  memberships Membership[]
  queryLogs   QueryLog[]
}

model Organization {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  // `plan` stays a STORED column — the sole entitlement value read by
  // uploadController and getStats. It is recomputed and written by the shared
  // entitlement service (Step 2b) whenever a Subscription source changes; it is
  // NEVER computed at read time.
  plan         PlanType  @default(FREE)
  // Manual entitlement floor. null = derive purely from Subscription sources.
  // Non-null = a manual grant (e.g. ENTERPRISE deals, or the review account
  // which has no billing source). Webhooks must NEVER write this column.
  // Derivation contract: plan = max(planOverride ?? FREE, PRO if any source ACTIVE else FREE)
  // with ordering FREE(0) < PRO(1) < ENTERPRISE(2).
  planOverride PlanType?
  scanCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members          Membership[]
  documents        Document[]
  entities         Entity[]
  savedReports     SavedReportDefinition[]
  generatedReports GeneratedReport[]
  subscriptions    Subscription[]
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

// One row per (organization, billing source). Each source independently
// reports whether it is ACTIVE; the derived Organization.plan is PRO if ANY
// source is ACTIVE (subject to the planOverride floor). Per-source state lets
// Paddle (web) and RevenueCat (mobile) coexist on one entitlement.
model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @db.Uuid
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source           BillingSource
  status           SubscriptionStatus @default(INACTIVE)
  externalId       String? // Paddle subscription_id / RevenueCat original_transaction_id
  currentPeriodEnd DateTime?
  lastEventAt      DateTime? // occurred_at of last applied event (out-of-order guard, used in 2b)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([organizationId, source])
  @@index([organizationId])
}

enum BillingSource {
  PADDLE
  REVENUECAT
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
}

model Membership {
  id             String     @id @default(uuid()) @db.Uuid
  userId         String     @db.Uuid
  organizationId String     @db.Uuid
  role           MemberRole @default(MEMBER)
  joinedAt       DateTime   @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Document {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId            String       @db.Uuid // The user who uploaded it
  originalFileName  String
  fileUrl           String
  documentType      String
  documentSubtype   String?
  detectedLanguage  String
  rawText           String       @db.Text
  normalizedText    String       @db.Text
  summary           String?      @db.Text
  overallConfidence Float
  status            String
  uploadedAt        DateTime     @default(now())
  processedAt       DateTime?

  facts            DocumentFact[]
  documentEntities DocumentEntity[]

  @@index([organizationId])
  // PR-C1 dashboard analytics: the by-status breakdown groups on
  // (organizationId, status); the monthly series / period counts filter on
  // (organizationId, status, processedAt-range). These composite indexes let
  // those aggregations use an index scan instead of an org-scan + filter.
  @@index([organizationId, status])
  @@index([organizationId, processedAt])
}

model DocumentFact {
  id          String    @id @default(uuid()) @db.Uuid
  documentId  String    @db.Uuid
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  factType    String
  key         String
  valueString String?
  valueNumber Float?
  valueDate   DateTime?
  currency    String?
  confidence  Float
  sourceSpan  String
  isReviewed  Boolean   @default(false)

  @@index([documentId])
}

model Entity {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entityType     String
  canonicalName  String
  // Item B (Phase 1, additive): human-readable display name preserving original
  // casing/accents. Nullable, no default, no backfill in this migration — the
  // column lands and is deployed BEFORE any code reads or writes it. Existing
  // rows read as NULL; the display layer keeps falling back to aliases[0] /
  // canonicalName until a later phase populates and consumes this column.
  displayName    String?
  aliases        String[]
  metadataJson   Json
  createdAt      DateTime     @default(now())

  documentEntities DocumentEntity[]

  @@index([organizationId])
}

model DocumentEntity {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entityId   String   @db.Uuid
  entity     Entity   @relation(fields: [entityId], references: [id])
  role       String
  confidence Float

  @@index([documentId])
}

model QueryLog {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id])
  rawQueryText     String
  sourceLanguage   String
  parsedIntentJson Json
  queryPlanJson    Json
  executionTimeMs  Int
  resultCount      Int
  status           String
  errorMessage     String?
  createdAt        DateTime @default(now())
}

model SavedReportDefinition {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title             String
  description       String
  queryTemplateJson Json
  schedule          String?
  createdAt         DateTime     @default(now())

  generatedReports GeneratedReport[]

  @@index([organizationId])
}

model GeneratedReport {
  id               String                 @id @default(uuid()) @db.Uuid
  definitionId     String?                @db.Uuid
  definition       SavedReportDefinition? @relation(fields: [definitionId], references: [id])
  organizationId   String                 @db.Uuid
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            String
  summaryText      String                 @db.Text
  dataSnapshotJson Json
  locale           String
  createdAt        DateTime               @default(now())

  @@index([organizationId])
}

model WebhookEvent {
  // Source-namespaced event id, e.g. "paddle:evt_123" / "revenuecat:<id>".
  // Namespacing prevents a RevenueCat event id from colliding with a Paddle one
  // on this PK (which would silently drop a paid event as a "duplicate").
  // The PK column type is unchanged (TEXT) — namespacing is done at write time.
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())
}
