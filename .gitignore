# Dependencies
node_modules/

# Environment files — never commit credentials; .env.example is the template
.env
.env.*
!.env.example
# Exception: the frontend's production API base is public (already in the web
# bundle) and must be tracked so the Capacitor Android build is reproducible.
!apps/frontend/.env.production

# ── Capacitor / Android ──────────────────────────────────────────
# The android/ project IS committed (it's the native app). Only its generated
# build artifacts and local SDK pointers are ignored.
apps/frontend/android/.gradle/
apps/frontend/android/build/
apps/frontend/android/app/build/
apps/frontend/android/capacitor-cordova-android-plugins/
apps/frontend/android/local.properties
apps/frontend/android/.idea/
apps/frontend/android/app/src/main/assets/public/
apps/frontend/android/app/src/main/assets/capacitor.config.json
apps/frontend/android/app/src/main/assets/capacitor.plugins.json
*.keystore
*.jks
# Android signing config — holds keystore path + store/key passwords. Never commit.
apps/frontend/android/key.properties

# Build output
dist/
build/
.vite/
*.tsbuildinfo

# Logs & coverage
*.log
coverage/

# Local debug artifacts (DB dumps, captured API responses, scratch output)
db_dump*
*_response.json
*.local

# Sales data — lives in this folder locally but must never reach the repo
leads/

# Editor / OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/
