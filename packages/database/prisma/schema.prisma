generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @db.Uuid
  email             String   @unique
  preferredLanguage String   @default("en")
  createdAt         DateTime @default(now())

  memberships Membership[]
  queryLogs   QueryLog[]
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  plan      PlanType @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          Membership[]
  documents        Document[]
  entities         Entity[]
  savedReports     SavedReportDefinition[]
  generatedReports GeneratedReport[]
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

model Membership {
  id             String     @id @default(uuid()) @db.Uuid
  userId         String     @db.Uuid
  organizationId String     @db.Uuid
  role           MemberRole @default(MEMBER)
  joinedAt       DateTime   @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Document {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId            String       @db.Uuid // The user who uploaded it
  originalFileName  String
  fileUrl           String
  documentType      String
  documentSubtype   String?
  detectedLanguage  String
  rawText           String       @db.Text
  normalizedText    String       @db.Text
  summary           String?      @db.Text
  overallConfidence Float
  status            String
  uploadedAt        DateTime     @default(now())
  processedAt       DateTime?

  facts            DocumentFact[]
  documentEntities DocumentEntity[]

  @@index([organizationId])
}

model DocumentFact {
  id          String    @id @default(uuid()) @db.Uuid
  documentId  String    @db.Uuid
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  factType    String
  key         String
  valueString String?
  valueNumber Float?
  valueDate   DateTime?
  currency    String?
  confidence  Float
  sourceSpan  String
  isReviewed  Boolean   @default(false)

  @@index([documentId])
}

model Entity {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entityType     String
  canonicalName  String
  aliases        String[]
  metadataJson   Json
  createdAt      DateTime     @default(now())

  documentEntities DocumentEntity[]

  @@index([organizationId])
}

model DocumentEntity {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entityId   String   @db.Uuid
  entity     Entity   @relation(fields: [entityId], references: [id])
  role       String
  confidence Float

  @@index([documentId])
}

model QueryLog {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id])
  rawQueryText     String
  sourceLanguage   String
  parsedIntentJson Json
  queryPlanJson    Json
  executionTimeMs  Int
  resultCount      Int
  status           String
  errorMessage     String?
  createdAt        DateTime @default(now())
}

model SavedReportDefinition {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title             String
  description       String
  queryTemplateJson Json
  schedule          String?
  createdAt         DateTime     @default(now())

  generatedReports GeneratedReport[]

  @@index([organizationId])
}

model GeneratedReport {
  id               String                 @id @default(uuid()) @db.Uuid
  definitionId     String?                @db.Uuid
  definition       SavedReportDefinition? @relation(fields: [definitionId], references: [id])
  organizationId   String                 @db.Uuid
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            String
  summaryText      String                 @db.Text
  dataSnapshotJson Json
  locale           String
  createdAt        DateTime               @default(now())

  @@index([organizationId])
}
